{
  "name": "viktor-rolf-qc-system",
  "version": "1.0.0",
  "description": "Quality Control & Supplier Communication System for Viktor & Rolf",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd backend && npm run dev",
    "client": "cd frontend && npm run dev",
    "build": "cd frontend && npm install && npm run build",
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "keywords": [
    "fashion",
    "quality-control",
    "supplier-management"
  ],
  "author": "Viktor & Rolf",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "@supabase/supabase-js": "^2.89.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "serverless-http": "^4.0.0",
    "uuid": "^9.0.1"
  }
}
